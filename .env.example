# STT providers
# Primary provider: deepgram | openai | whisper
INTERVIEW_STT_PROVIDER=openai
# Optional fallback chain, comma-separated (example: openai,whisper)
INTERVIEW_STT_FALLBACKS=

DEEPGRAM_API_KEY=
DEEPGRAM_MODEL=nova-2

# OpenAI (shared for LLM + TTS + optional STT)
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_STT_MODEL=whisper-1
OPENAI_STT_LANGUAGE=en
OPENAI_TTS_MODEL=gpt-4o-mini-tts
OPENAI_TTS_VOICE=alloy

# Local Whisper CLI (optional fallback)
WHISPER_COMMAND=whisper
WHISPER_MODEL=base
WHISPER_LANGUAGE=en
WHISPER_TIMEOUT_MS=120000

# TTS provider: elevenlabs | openai
INTERVIEW_TTS_PROVIDER=openai

ELEVENLABS_API_KEY=
ELEVENLABS_MODEL_ID=eleven_turbo_v2_5
ELEVENLABS_VOICE_ID=EXAVITQu4vr4xnSDxMaL

# Interview LLM provider: openai | xai | google
INTERVIEW_LLM_PROVIDER=openai
# Optional fallback chain, comma-separated (example: xai,google)
INTERVIEW_LLM_FALLBACKS=

# Optional per-provider model defaults
INTERVIEW_LLM_MODEL=
INTERVIEW_LLM_OPENAI_MODEL=gpt-4.1-mini
INTERVIEW_LLM_XAI_MODEL=grok-2-latest
INTERVIEW_LLM_GOOGLE_MODEL=gemini-2.0-flash

# xAI (Grok)
XAI_API_KEY=
XAI_BASE_URL=https://api.x.ai/v1

# Google Gemini
GOOGLE_API_KEY=
# GEMINI_API_KEY=   # alias supported

# --- Optional hardening/runtime controls ---
# Consent/versioning
INTERVIEW_CONSENT_VERSION=v1
# Retention days for stored interview sessions/messages/scores
INTERVIEW_RETENTION_DAYS=7

# Rate limits
INTERVIEW_RATE_SESSION_CREATE=5
INTERVIEW_RATE_SESSION_CREATE_WINDOW_MS=900000
INTERVIEW_RATE_TURNS=40
INTERVIEW_RATE_TURNS_WINDOW_MS=60000
INTERVIEW_RATE_SCORECARD=10
INTERVIEW_RATE_SCORECARD_WINDOW_MS=600000
INTERVIEW_RATE_STT=40
INTERVIEW_RATE_STT_WINDOW_MS=60000
INTERVIEW_RATE_TTS=40
INTERVIEW_RATE_TTS_WINDOW_MS=60000

# Session and payload caps
INTERVIEW_MAX_CANDIDATE_TURNS=25
INTERVIEW_MAX_SESSION_DURATION_MIN=90
INTERVIEW_MAX_AUDIO_BYTES=5242880
